{
  "name": "@swit/desktop",
  "version": "1.0.0",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run build --workspace=@swit/server && electron-vite build && node scripts/bundle-server.mjs",
    "start": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac --arm64 --x64",
    "typecheck": "npm run build --workspace=@swit/shared && tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@xyflow/react": "^12.11.0",
    "better-sqlite3": "^11.3.0",
    "date-fns": "^3.6.0",
    "electron-store": "^8.2.0",
    "fastify": "^4.28.1",
    "lucide-react": "^0.439.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.7",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@swit/shared": "*",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.1",
    "vitest": "^2"
  },
  "build": {
    "appId": "day.swit.app",
    "productName": "SWIT Day",
    "electronVersion": "32.3.3",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "out/server/node_modules",
        "to": "app.asar.unpacked/out/server/node_modules"
      }
    ],
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "asarUnpack": [
      "out/server/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/node_modules/@swit/**",
      "!**/node_modules/**/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/**/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/**/*.d.ts",
      "!**/node_modules/**/*.map",
      "!**/node_modules/.bin"
    ]
  }
}
