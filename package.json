{
  "name": "swit-day",
  "version": "1.0.0",
  "private": true,
  "description": "SWIT Day — персональный планировщик рабочего дня",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/desktop",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:desktop": "npm run dev --workspace=packages/desktop",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspace=packages/desktop",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
